default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # 1. 自动处理 CI 环境下的钥匙串限制
    setup_ci if is_ci

    # 2. 从环境变量初始化 API Key
    # 这里的变量名要和 GitHub YAML 中的 env 保持一致
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: false # 如果你直接复制的 .p8 文本，设为 false
    )

    # 3. 使用 api_key 执行 match
    # match 会自动在本地/CI 安装描述文件，不再需要 Apple ID 密码
    match(
      type: "appstore", 
      readonly: is_ci,
      api_key: api_key
    )

    # 4. 自增版本号
    increment_build_number(
      build_number: latest_testflight_build_number(api_key: api_key) + 1,
      xcodeproj: "MYRN.xcodeproj"
    )

    # 5. 编译 App
    build_app(
      workspace: "MYRN.xcworkspace", 
      scheme: "MYRN",
      export_method: "app-store",
      clean: true
    )

    # 6. 使用 api_key 上传到 TestFlight
    # 这一步彻底告别 "Missing password" 或 "Invalid username" 报错
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end